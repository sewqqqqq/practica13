<Window x:Class="MediaLibraryApp.LoginPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediaLibraryApp - Вход"
        Width="1080"
        Height="680"
        Style="{StaticResource WindowStyle}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*"/>
            <ColumnDefinition Width="0.95*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="48">
            <Border CornerRadius="28" Background="{StaticResource SecondaryBackgroundBrush}" Padding="40">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Image Source="Assets/logo.png" Width="110" Height="110" HorizontalAlignment="Left"/>
                        <TextBlock Margin="0,24,0,8" Text="Личная медиатека" Style="{StaticResource HeaderTextStyle}"/>
                        <TextBlock Width="360"
                                   Text="Управляйте фильмами, сериалами, книгами, музыкой и играми в одном приложении."
                                   TextWrapping="Wrap"
                                   Style="{StaticResource SubHeaderTextStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <Border Width="360" Height="10" CornerRadius="5" Background="{StaticResource PrimaryAccentBrush}" HorizontalAlignment="Left"/>
                        <TextBlock Margin="0,24,0,12" FontSize="30" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="MEDIA FLOW"/>
                        <TextBlock Width="420"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="16"
                                   Text="Авторизация и регистрация оформлены в едином фирменном стиле медиаплеера: тёмная база, оранжевый акцент и голубые навигационные элементы."/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Fill="{StaticResource PrimaryAccentBrush}"/>
                        <Ellipse Width="12" Height="12" Margin="8,0,0,0" Fill="{StaticResource SecondaryAccentBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1" Margin="0,48,48,48">
            <Border MaxWidth="420"
                    Padding="36"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource SecondaryBackgroundBrush}"
                    CornerRadius="24">
                <StackPanel>
                    <Image Source="Assets/logo.png" Width="84" Height="84" HorizontalAlignment="Center"/>
                    <TextBlock Margin="0,20,0,8" HorizontalAlignment="Center" Text="Вход в систему" Style="{StaticResource HeaderTextStyle}"/>
                    <TextBlock Margin="0,0,0,24"
                               HorizontalAlignment="Center"
                               Text="Введите логин или email и пароль"
                               Style="{StaticResource SubHeaderTextStyle}"/>

                    <TextBlock Text="Логин или Email" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="LoginTextBox" Style="{StaticResource InputTextBoxStyle}"/>

                    <TextBlock Text="Пароль" Style="{StaticResource FieldLabelStyle}"/>
                    <PasswordBox x:Name="PasswordInput" Style="{StaticResource InputPasswordBoxStyle}"/>

                    <Button Margin="0,8,0,16"
                            Content="Войти"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="LoginButton_Click"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="Нет аккаунта? "/>
                        <Button Content="Зарегистрироваться"
                                Style="{StaticResource LinkButtonStyle}"
                                Click="OpenRegistrationButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
