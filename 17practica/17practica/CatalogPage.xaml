<Window x:Class="MediaLibraryApp.CatalogPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Каталог"
        Width="1200"
        Height="760"
        Style="{StaticResource WindowStyle}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="20"
                Background="{StaticResource SecondaryBackgroundBrush}"
                CornerRadius="16">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Каталог медиаконтента"
                               Style="{StaticResource HeaderTextStyle}"/>
                    <TextBlock Text="CRUD + поиск + фильтрация + сортировка"
                               Style="{StaticResource SubHeaderTextStyle}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Выйти"
                        Width="100"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="LogoutButton_Click"/>
            </Grid>
        </Border>

        <!-- TOOLBAR (CRUD + SEARCH + FILTER) -->
        <Border Grid.Row="1"
                Margin="0,0,0,16"
                Padding="12"
                Background="{StaticResource SecondaryBackgroundBrush}"
                CornerRadius="16">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <!-- CRUD buttons -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="Добавить" Margin="0,0,8,0" />
                    <Button Content="Редактировать" Margin="0,0,8,0"/>
                    <Button Content="Удалить"/>
                </StackPanel>

                <!-- SEARCH (без PlaceholderText!) -->
                <Grid Grid.Column="1" Margin="12,0">
                    <TextBox x:Name="SearchBox"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged"/>

                    <!-- watermark -->
                    <TextBlock Text="Поиск..."
                               Margin="8,0,0,0"
                               Foreground="Gray"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- FILTER -->
                <ComboBox Grid.Column="2"
                          Margin="12,0"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Все статусы"/>
                    <ComboBoxItem Content="Хочу посмотреть"/>
                    <ComboBoxItem Content="В процессе"/>
                    <ComboBoxItem Content="Просмотрено"/>
                </ComboBox>

                <!-- SORT -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <ComboBox Width="120" SelectedIndex="0">
                        <ComboBoxItem Content="Название"/>
                        <ComboBoxItem Content="Год"/>
                        <ComboBoxItem Content="Рейтинг"/>
                    </ComboBox>

                    <Button Content="⇅" Width="40" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LIST -->
        <ScrollViewer Grid.Row="2">
            <ListView x:Name="CatalogListView"
                      Background="Transparent"
                      BorderThickness="0">

                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>

                <ListView.ItemTemplate>
                    <DataTemplate>

                        <Border Width="260"
                                Margin="8"
                                Padding="12"
                                Background="{StaticResource SecondaryBackgroundBrush}"
                                CornerRadius="14">

                            <StackPanel>

                                <!-- IMAGE -->
                                <Grid Height="140">
                                    <Image Source="{Binding Poster}"
                                           Stretch="UniformToFill"/>

                                    <Border Background="#55000000">
                                        <TextBlock Text="Нет изображения"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>

                                <!-- TITLE -->
                                <TextBlock Text="{Binding Title}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Margin="0,10,0,0"/>

                                <!-- DESC -->
                                <TextBlock Text="{Binding ShortDescription}"
                                           TextWrapping="Wrap"
                                           Foreground="Gray"
                                           Margin="0,6,0,0"/>

                                <!-- TAGS -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">

                                    <Border Background="#3333AAFF"
                                            Padding="6,2"
                                            CornerRadius="8"
                                            Margin="0,0,6,0">
                                        <TextBlock Text="{Binding StatusName}"
                                                   FontSize="11"/>
                                    </Border>

                                    <Border Background="#3322CC88"
                                            Padding="6,2"
                                            CornerRadius="8">
                                        <TextBlock Text="{Binding Difficulty}"
                                                   FontSize="11"/>
                                    </Border>

                                </StackPanel>

                            </StackPanel>
                        </Border>

                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </ScrollViewer>

    </Grid>
</Window>