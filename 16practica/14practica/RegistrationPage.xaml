<Window x:Class="MediaLibraryApp.RegistrationPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediaLibraryApp - Регистрация"
        Width="1080"
        Height="760"
        Style="{StaticResource WindowStyle}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.92*"/>
            <ColumnDefinition Width="1.08*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="48">
            <Border CornerRadius="28" Background="{StaticResource SecondaryBackgroundBrush}" Padding="36">
                <StackPanel VerticalAlignment="Center">
                    <Image Source="Assets/logo.png" Width="120" Height="120" HorizontalAlignment="Center"/>
                    <TextBlock Margin="0,22,0,10" HorizontalAlignment="Center" Text="Новый профиль медиатеки" Style="{StaticResource HeaderTextStyle}"/>
                    <TextBlock Width="320"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Style="{StaticResource SubHeaderTextStyle}"
                               Text="Зарегистрируйтесь, чтобы хранить подборки, оценки и статусы просмотра в единой системе."/>

                    <Border Margin="0,28,0,0" Padding="18" CornerRadius="18" Background="#22333333">
                        <StackPanel>
                            <TextBlock FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" Text="Что будет доступно"/>
                            <TextBlock Margin="0,12,0,0" Foreground="{StaticResource MutedTextBrush}" Text="• каталог фильмов, сериалов, книг, игр и музыки"/>
                            <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" Text="• статусы просмотра и личные списки"/>
                            <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" Text="• отзывы и оценки контента"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Column="1" Margin="0,48,48,48">
            <Border MaxWidth="460"
                    Padding="36"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource SecondaryBackgroundBrush}"
                    CornerRadius="24">
                <StackPanel>
                    <Image Source="Assets/logo.png" Width="80" Height="80" HorizontalAlignment="Center"/>
                    <TextBlock Margin="0,18,0,8" HorizontalAlignment="Center" Text="Регистрация" Style="{StaticResource HeaderTextStyle}"/>
                    <TextBlock Margin="0,0,0,24"
                               HorizontalAlignment="Center"
                               Text="Создайте новую учётную запись"
                               Style="{StaticResource SubHeaderTextStyle}"/>

                    <TextBlock Text="ФИО" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="FullNameTextBox" Style="{StaticResource InputTextBoxStyle}"/>

                    <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="EmailTextBox" Style="{StaticResource InputTextBoxStyle}"/>

                    <TextBlock Text="Пароль" Style="{StaticResource FieldLabelStyle}"/>
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource InputPasswordBoxStyle}"/>

                    <TextBlock Text="Подтверждение пароля" Style="{StaticResource FieldLabelStyle}"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource InputPasswordBoxStyle}"/>

                    <Button Margin="0,8,0,16"
                            Content="Зарегистрироваться"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="RegisterButton_Click"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Text="Уже есть аккаунт? "/>
                        <Button Content="Войти"
                                Style="{StaticResource LinkButtonStyle}"
                                Click="OpenLoginButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
